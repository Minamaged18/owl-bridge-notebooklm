{
  "name": "owl-bridge-notebooklm",
  "version": "3.0.0",
  "description": "🦉 OWL Bridge — Next-gen MCP server for Google NotebookLM with cookie injection, VNC + headless server support, and stealth Chrome automation.",
  "type": "module",
  "bin": {
    "owl-bridge-notebooklm": "dist/index.js",
    "notebooklm-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "watch": "tsc --watch",
    "dev": "tsx watch src/index.ts",
    "prepare": "npm run build",
    "test": "tsx src/index.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "check": "npm run format:check && npm run lint && npm run build",
    "inject-cookies": "node scripts/extract_chrome_cookies.js"
  },
  "keywords": [
    "mcp",
    "notebooklm",
    "gemini",
    "ai",
    "claude",
    "cookie-injection",
    "headless",
    "vnc",
    "stealth",
    "owl-bridge"
  ],
  "author": "Mina Maged (fork of PleasePrompto/notebooklm-mcp)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minamaged18/notebooklm-mcp.git"
  },
  "homepage": "https://github.com/Minamaged18/notebooklm-mcp#readme",
  "bugs": {
    "url": "https://github.com/Minamaged18/notebooklm-mcp/issues"
  },
  "files": [
    "dist",
    "README.md",
    "COOKIE_INJECTION.md",
    "LICENSE",
    "scripts",
    "docs"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "env-paths": "^3.0.0",
    "globby": "^14.1.0",
    "patchright": "^1.48.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
